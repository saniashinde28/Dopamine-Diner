<% layout("/layouts/boilerplate") %>


    <div class="row">
        <div class="col-8 offset-2">
            <div class="container mt-4">
                <h3 class="mb-4">Add a New Activity</h3>

                <form method="post" action="/listings">

                    <div class="form-group mb-3">
                        <label for="name" class="form-label">Activity Name</label>
                        <input type="text" name="listing[name]" id="name" placeholder="Add a catchy name" minlength="3" maxlength="80"
                            class="form-control">
                    </div>

                    <div class="form-group mb-3">
                        <label for="category" class="form-label">Category</label>
                        <select id="category" name="listing[category]" class="form-control" required>
                            <option value="">--Select--</option>
                            <option value="starter">Starter</option>
                            <option value="main">Main</option>
                            <option value="dessert">Dessert</option>
                        </select>
                    </div>

                    <div class="form-group mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea name="listing[description]" id="description" rows="3" required minlength="10"
                            maxlength="300" class="form-control"></textarea>
                    </div>

                    <div class="row">
                        <div class="form-group mb-3 col-md-4">
                            <label for="duration" class="form-label">Duration (minutes)</label>
                            <input type="number" name="listing[duration]" id="duration" min="1" max="180"
                                class="form-control">
                            <small class="text-muted">
                                Dessert activities should not exceed 90 minutes
                            </small>
                        </div>

                        <div class="form-group mb-3 col-md-8">
                            <label for="impactLevel" class="form-label">Impact Level</label>
                            <select name="listing[impactLevel]" id="impactLevel" class="form-control" required>
                                <option value="">--Select--</option>
                                <option value="low">Low</option>
                                <option value="medium">Medium</option>
                                <option value="high">High</option>
                            </select>
                        </div>

                        <div class="form-group mb-3 col-12">
                            <label for="effort" class="form-label">Effort</label>
                            <select name="listing[effort]" id="effort" class="form-control" required>
                                <option value="">--Select--</option>
                                <option value="easy">Easy</option>
                                <option value="moderate">Moderate</option>
                                <option value="hard">Hard</option>
                            </select>
                        </div>
                    </div>



                    <div class="form-group mb-3">
                        <label for="moodTags" class="form-label">
                            Mood Tags (comma-separated)
                        </label>
                        <input type="text" name="listing[moodTags]" id="moodTags" placeholder="neutral, energetic"
                            class="form-control">
                    </div>

                    <div class="form-group mb-3">
                        <label for="image" class="form-label">Image URL</label>
                        <input type="text" name="listing[image]" id="image" placeholder="https://example.com/image.jpg"
                            class="form-control">
                    </div>

                    <button class="btn btn-dark mt-3">Add Activity</button>
                    <br>
                    <br>

                </form>
            </div>
        </div>
    </div>