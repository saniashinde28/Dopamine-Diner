<% layout("/layouts/boilerplate") %>

<div class="container mt-4 activity-show">

  <div class="row">


<!-- LEFT → Image -->
<div class="col-md-5">
  <div class="activity-img-box">
    <img 
      src="<%= listing.image %>" 
      alt="<%= listing.name %>"
      class="activity-img"
    >
  </div>
</div>

<!-- RIGHT → Details -->
<div class="col-md-7">

  <h3 class="mb-3"><%= listing.name %></h3>

  <div class="activity-info">

    <div class="info-row">
      <span class="info-label">Category</span>
      <span class="info-value"><%= listing.category %></span>
    </div>

    <div class="info-row">
      <span class="info-label">Duration</span>
      <span class="info-value"><%= listing.duration %> mins</span>
    </div>

    <div class="info-row">
      <span class="info-label">Impact</span>
      <span class="info-value"><%= listing.impactLevel %></span>
    </div>

    <div class="info-row">
      <span class="info-label">Effort</span>
      <span class="info-value"><%= listing.effort %></span>
    </div>

    <div class="info-row">
      <span class="info-label">Mood Tags</span>
      <span class="info-value"><%= listing.moodTags.join(', ') %></span>
    </div>

  </div>

  <div class="mt-3">
    <p class="activity-desc">
      <%= listing.description %>
    </p>
  </div>

  <div class="activity-actions mt-4">
    <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark me-2">
      Edit
    </a>

    <form 
      method="post"
      action="/listings/<%=listing._id%>?_method=delete"
      class="d-inline"
    >
      <button class="btn btn-outline-dark">
        Delete
      </button>
    </form>
  </div>

</div>


  </div>

</div>

