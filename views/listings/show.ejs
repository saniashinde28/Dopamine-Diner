<% layout("/layouts/boilerplate") %>

  <div class="container mt-4 activity-show">

    <div class="row">


      <!-- LEFT → Image -->
      <div class="col-md-5">
        <div class="activity-img-box">
          <img src="<%= listing.image %>" alt="<%= listing.name %>" class="activity-img">
        </div>
      </div>

      <!-- RIGHT → Details -->
      <div class="col-md-7">

        <h3 class="mb-3">
          <%= listing.name %>
        </h3>

        <div class="activity-info">

          <div class="info-row">
            <span class="info-label">Category</span>
            <span class="info-value">
              <%= listing.category %>
            </span>
          </div>

          <div class="info-row">
            <span class="info-label">Duration</span>
            <span class="info-value">
              <%= listing.duration %> mins
            </span>
          </div>

          <div class="info-row">
            <span class="info-label">Impact</span>
            <span class="info-value">
              <%= listing.impactLevel %>
            </span>
          </div>

          <div class="info-row">
            <span class="info-label">Effort</span>
            <span class="info-value">
              <%= listing.effort %>
            </span>
          </div>

          <div class="info-row">
            <span class="info-label">Mood Tags</span>
            <span class="info-value">
              <%= listing.moodTags.join(', ') %></span>
    </div>

  </div>

  <div class="mt-3">
    <p class="activity-desc">
      <%= listing.description %>
    </p>
  </div>

  <div class="activity-actions mt-4">
    <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark me-2">
      Edit
    </a>

    <form 
      method="post"
      action="/listings/<%=listing._id%>?_method=delete"
      class="d-inline"
    >
      <button class="btn btn-outline-dark">
        Delete
      </button>
    </form>
  </div>

</div>


  </div>
<hr>
  <div class="row justify-content-center mt-4">
  <div class="col-md-6">

    <h4 class="mb-4">Share your Boost Experience</h4>

    <form action="/listings/<%=listing._id%>/reviews" method="post" novalidate class="needs-validation">

      <!-- Rating -->
      <div class="mb-3">
        <label for="rating" class="form-label fw-semibold">Rating</label>
        <input
          type="range"
          min="1"
          max="5"
          step="1"
          id="rating"
          name="review[rating]"
          class="form-range"
        >
        <div class="d-flex justify-content-between small text-muted">
          <span>1</span>
          <span>5</span>
        </div>
      </div>

      <!-- Comment -->
      <div class="mb-3">
        <label for="comment" class="form-label fw-semibold">Comment</label>
        <textarea
          id="comment"
          name="review[comment]"
          rows="3"
          class="form-control"
          placeholder="Write your experience"
          required
        ></textarea>
        <div class="invalid-feedback">Please share your experience</div>
      </div>

      <!-- Button -->
      <div class="mt-4 mb-3">
        <button class="btn btn-dark">Submit</button>
      </div>

    </form>

  </div>
</div>

</div>